# pnpm + npm behavior for the workspace. Committed so every contributor
# and CI run share identical behavior. npm auth tokens live in
# ~/.npmrc or in environment variables — never here.

# Modern, strict resolution defaults
resolution-mode=highest
strict-peer-dependencies=true
auto-install-peers=true
save-workspace-protocol=rolling

# npm publish defaults — each package's `publishConfig.access` already
# sets `public`, but this makes the intent explicit at the workspace level.
access=public

# Provenance is enabled via NPM_CONFIG_PROVENANCE env var in the release
# workflow (requires OIDC / `id-token: write`). Setting it here would fail
# local `pnpm publish` runs outside that OIDC context.
