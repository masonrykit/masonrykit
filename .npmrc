# Settings that both npm AND pnpm read. pnpm-only settings live in
# `pnpm-workspace.yaml` to avoid npm's "Unknown project config" warnings.
# npm auth tokens live in ~/.npmrc or in environment variables — never here.

# npm publish defaults — each package's `publishConfig.access` already
# sets `public`, but this makes the intent explicit at the workspace level.
access=public

# Block installs whose Node version is below what `engines.node` in
# package.json requires. Catches contributors trying to develop on
# unsupported Node versions (and keeps CI honest).
engine-strict=true

# Provenance is enabled via NPM_CONFIG_PROVENANCE env var in the release
# workflow (requires OIDC / `id-token: write`). Setting it here would fail
# local `pnpm publish` runs outside that OIDC context.
