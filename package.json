{
  "name": "masonrykit",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for MasonryKit: @masonrykit/browser and @masonrykit/react",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docs": "pnpm -r docs",
    "format": "prettier --write .",
    "dev:vite": "pnpm --filter @masonrykit/app-vite dev",
    "dev:vite-react": "pnpm --filter @masonrykit/app-vite-react dev",
    "build:vite": "pnpm --filter @masonrykit/app-vite build",
    "build:vite-react": "pnpm --filter @masonrykit/app-vite-react build",
    "preview:vite": "pnpm --filter @masonrykit/app-vite preview",
    "preview:vite-react": "pnpm --filter @masonrykit/app-vite-react preview",
    "setup": "mise install && pnpm install",
    "test:react": "pnpm --filter @masonrykit/react test",
    "test:react:browser": "pnpm --filter @masonrykit/react run test:browser",
    "test:react:ui": "pnpm --filter @masonrykit/react run test:browser:ui",
    "test:react:headed": "pnpm --filter @masonrykit/react run test:browser:headed",
    "test:react:preview:ui": "pnpm --filter @masonrykit/react run test:preview:ui",
    "test:core": "pnpm --filter @masonrykit/core test",
    "test:install:browsers": "pnpm exec playwright install",
    "changeset": "changeset",
    "release:version": "changeset version && pnpm install",
    "release:publish": "pnpm -r build && changeset publish",
    "release": "pnpm run release:version && pnpm run release:publish",
    "api:extract": "echo \"api:extract disabled\"",
    "api:md": "echo \"api:md disabled\"",
    "api": "echo \"api disabled\"",
    "analyze:bundle": "pnpm -r exec -- du -sh dist 2>/dev/null | sort -hr || echo 'No dist directories found'",
    "analyze:deps": "pnpm ls --depth=0",
    "analyze:outdated": "pnpm outdated --recursive",
    "benchmark": "node scripts/benchmark.js"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/browser": "3.2.4",
    "@vitejs/plugin-react": "5.0.2",
    "playwright": "1.55.0",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@types/node": "24.3.1",
    "tsdown": "0.14.2",
    "tslib": "2.8.1",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "@changesets/cli": "2.29.6",
    "@changesets/changelog-github": "0.5.1"
  }
}
