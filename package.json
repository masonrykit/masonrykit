{
  "name": "masonrykit",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for MasonryKit: @masonrykit/browser and @masonrykit/react",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "scripts": {
    "prepare": "lefthook install || true",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:unused": "knip",
    "typecheck": "pnpm -r typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "dev:vite": "pnpm --filter @masonrykit/app-vite dev",
    "dev:vite-react": "pnpm --filter @masonrykit/app-vite-react dev",
    "build:vite": "pnpm --filter @masonrykit/app-vite build",
    "build:vite-react": "pnpm --filter @masonrykit/app-vite-react build",
    "preview:vite": "pnpm --filter @masonrykit/app-vite preview",
    "preview:vite-react": "pnpm --filter @masonrykit/app-vite-react preview",
    "setup": "mise install && pnpm install",
    "test:react:browser": "pnpm --filter @masonrykit/react run test:browser",
    "test:react:ui": "pnpm --filter @masonrykit/react run test:browser:ui",
    "test:react:headed": "pnpm --filter @masonrykit/react run test:browser:headed",
    "test:install:browsers": "pnpm exec playwright install chromium",
    "changeset": "changeset",
    "release:version": "changeset version && pnpm install",
    "release:publish": "pnpm -r build && changeset publish",
    "release": "pnpm run release:version && pnpm run release:publish",
    "analyze:bundle": "node scripts/check-bundle-size.js",
    "analyze:outdated": "pnpm outdated --recursive",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
