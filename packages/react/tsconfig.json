{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "rootDir": ".",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src", "test", "tests", "__tests__"],
  "exclude": ["dist", "build", "node_modules"],
  "references": [{ "path": "../core" }, { "path": "../browser" }]
}
