{
  "name": "@masonrykit/core",
  "version": "0.0.0",
  "description": "Pure, framework-agnostic layout computation for masonry grids. Multi-span items, stamps, and deterministic positioning.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "masonry",
    "grid",
    "layout",
    "waterfall",
    "pinterest",
    "typescript",
    "framework-agnostic",
    "multi-span",
    "stamps"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masonrykit/masonrykit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/masonrykit/masonrykit/issues"
  },
  "homepage": "https://github.com/masonrykit/masonrykit#readme",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  }
}
