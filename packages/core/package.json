{
  "name": "@masonrykit/core",
  "version": "0.0.0",
  "description": "Pure, framework-agnostic layout computation for masonry grids. Multi-span items, stamps, and deterministic positioning.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --platform node",
    "dev": "tsdown --watch --platform node",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api:extract": "api-extractor run --local"
  },
  "keywords": [
    "masonry",
    "grid",
    "layout",
    "waterfall",
    "pinterest",
    "typescript",
    "framework-agnostic",
    "multi-span",
    "stamps"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masonrykit/masonrykit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/masonrykit/masonrykit/issues"
  },
  "homepage": "https://github.com/masonrykit/masonrykit#readme",
  "publishConfig": {
    "access": "public"
  }
}
