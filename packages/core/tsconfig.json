{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020"],

    "declaration": true,
    "declarationMap": true,

    "types": []
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "**/*.test.*", "tests", "__tests__"]
}
